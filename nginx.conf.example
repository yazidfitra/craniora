# Nginx config untuk Craniora Academy
# Copy ke: /etc/nginx/sites-available/craniora
# Symlink: ln -s /etc/nginx/sites-available/craniora /etc/nginx/sites-enabled/
# Reload: sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name craniora.academy www.craniora.academy;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name craniora.academy www.craniora.academy;

    # SSL (Let's Encrypt)
    ssl_certificate /etc/letsencrypt/live/craniora.academy/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/craniora.academy/privkey.pem;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    # Proxy to Next.js
    location / {
        proxy_pass http://localhost:3210;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Cache static assets
    location /_next/static {
        proxy_pass http://localhost:3210;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # Service worker
    location /sw.js {
        proxy_pass http://localhost:3210;
        add_header Cache-Control "no-cache";
    }

    # Manifest
    location /manifest.json {
        proxy_pass http://localhost:3210;
        add_header Cache-Control "no-cache";
    }
}
